# ============================================================
# JNV API — CodeIgniter 4 Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

CI_ENVIRONMENT = production

# The full base URL where the API is accessible
# Examples:
#   https://www.jnv.co.za/api/
#   https://api.jnv.co.za/
app.baseURL = 'https://www.jnv.co.za/api/'

# Allowed CORS origin — the domain serving the static Nuxt site
# Use * to allow all origins (not recommended in production)
app.allowedOrigins = 'https://www.jnv.co.za'

# ---- Database -----------------------------------------------
database.default.hostname = localhost
database.default.database = jnv_cms
database.default.username = dbuser
database.default.password = dbpassword
database.default.DBDriver = MySQLi
database.default.port     = 3306
database.default.charset  = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci

# ---- Email (SMTP) -------------------------------------------
email.protocol   = smtp
email.SMTPHost   = smtp.gmail.com
email.SMTPUser   = your-gmail@gmail.com
email.SMTPPass   = your-app-password
email.SMTPPort   = 587
email.SMTPCrypto = tls
email.fromEmail  = your-gmail@gmail.com
email.fromName   = JNV Training and Development

# ---- Contact form -------------------------------------------
# Where contact form submissions are delivered
jnv.contactToEmail = info@jnv.co.za
